{
  "game": {
    "bout_win_score":        5,
    "winner_reset_delay_ms": 5000
  },

  "gamepad": {
    "score_limit_button":    1,
    "reset_button":          2,
    "clock_toggle_button":   3,
    "start_sequence_button": 0
  },

  "start_sequence": {
    "initial_delay_ms":    2000,
    "random_delay_min_ms": 750,
    "random_delay_max_ms": 2000
  },

  "screen": {
    "width": 1280,
    "height": 720,
    "fps": 30
  },

  "colors": {
    "black":         [0,   0,   0],
    "white":         [255, 255, 255],
    "red_bright":    [220, 30,  30],
    "red_dim":       [60,  10,  10],
    "green_bright":  [30,  200, 30],
    "green_dim":     [10,  50,  10],
    "yellow_bright": [220, 200, 30],
    "yellow_dim":    [50,  45,  10],
    "gray":          [180, 180, 180],
    "dark_gray":     [40,  40,  40],
    "clock_color":   [200, 200, 200],
    "delta_color":   [180, 220, 255]
  },

  "fonts": {
    "score_size": 380,
    "clock_size": 140,
    "delta_size": 60
  },

  "layout": {
    "score_y_frac":       0.42,
    "left_score_x_frac":  0.165,
    "right_score_x_frac": 0.835,
    "clock_x_frac":       0.50,
    "clock_y_frac":       0.20,
    "delta_y_frac":       0.38,
    "indicator_w_frac":        0.22,
    "indicator_h_frac":        0.110,
    "indicator_y_frac":        0.80,
    "indicator_outline_width": 3,
    "pie_radius":         70,
    "pie_center_y_frac":  0.50
  },

  "timing": {
    "hit_window_ms":            300,
    "hit_indicator_duration_ms": 3000,
    "delta_display_ms":         10000,
    "disconnect_hit_count":     3,
    "disconnect_window_ms":     12500,
    "disconnect_silence_ms":    5000
  },

  "serial": {
    "default_port": "/dev/ttyUSB0",
    "default_baud": 19200
  },

  "audio": {
    "hit_on_target_file":  "sounds/hit_on_target.wav",
    "hit_off_target_file": "sounds/hit_off_target.wav",
    "reset_file":          "sounds/reset.wav",
    "touch_left_file":     "sounds/touch_left.wav",
    "touch_right_file":    "sounds/touch_right.wav",
    "halt_file":           "sounds/halt.wav",
    "time_expired_file":   "sounds/time_expired.wav",
    "en_garde_file":       "sounds/en_garde.wav",
    "ready_file":          "sounds/ready.wav",
    "fence_file":          "sounds/fence.wav",
    "mixer_buffer": 2048,
    "announcement": {
      "gap_after_touch_ms":        750,
      "gap_between_words_ms":      200,
      "gap_between_scores_ms":     200,
      "gap_score_to_all_ms":       100,
      "gap_after_winner_name_ms":  400
    },
    "tones": {
      "hit_on_target":  {"frequency": 1000, "duration_ms": 1500},
      "hit_off_target": {"frequency": 1000, "duration_ms": 1500},
      "reset":          {"frequency": 300,  "duration_ms": 300},
      "touch": {
        "notes": [
          {"frequency": 900,  "duration_ms": 250},
          {"frequency": 1200, "duration_ms": 250}
        ]
      },
      "halt_beeps": {
        "notes": [
          {"frequency": 880, "duration_ms": 100},
          {"frequency": 0,   "duration_ms": 80}
        ],
        "repeats": 6
      }
    }
  }
}
