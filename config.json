{
  "screen": {
    "width": 1280,
    "height": 720,
    "fps": 30
  },

  "colors": {
    "black":         [0,   0,   0],
    "white":         [255, 255, 255],
    "red_bright":    [220, 30,  30],
    "red_dim":       [60,  10,  10],
    "green_bright":  [30,  200, 30],
    "green_dim":     [10,  50,  10],
    "yellow_bright": [220, 200, 30],
    "yellow_dim":    [50,  45,  10],
    "gray":          [180, 180, 180],
    "dark_gray":     [40,  40,  40],
    "clock_color":   [200, 200, 200],
    "delta_color":   [180, 220, 255]
  },

  "fonts": {
    "score_size": 380,
    "clock_size": 140,
    "delta_size": 60
  },

  "layout": {
    "score_y_frac":       0.42,
    "left_score_x_frac":  0.22,
    "right_score_x_frac": 0.78,
    "clock_x_frac":       0.50,
    "clock_y_frac":       0.20,
    "delta_y_frac":       0.38,
    "indicator_w_frac":   0.22,
    "indicator_h_frac":   0.110,
    "indicator_y_frac":   0.80,
    "pie_radius":         70,
    "pie_center_y_frac":  0.50
  },

  "timing": {
    "hit_window_ms":            250,
    "hit_indicator_duration_ms": 2500
  },

  "serial": {
    "default_port": "/dev/ttyUSB0",
    "default_baud": 19200
  },

  "audio": {
    "hit_on_target_file":  "sounds/hit_on_target.wav",
    "hit_off_target_file": "sounds/hit_off_target.wav",
    "reset_file":          "sounds/reset.wav",
    "mixer_buffer": 2048,
    "tones": {
      "hit_on_target":  {"frequency": 880, "duration_ms": 1000},
      "hit_off_target": {"frequency": 880, "duration_ms": 1000},
      "reset":          {"frequency": 300, "duration_ms": 300}
    }
  }
}
